# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Supabase PostgreSQL direct connection for Drizzle)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (Email)
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://events-hub-vert.vercel.app

# Check-in App V2
CHECKIN_APP_V2_ENABLED=true
NEXT_PUBLIC_CHECKIN_APP_V2_ENABLED=true
MOBILE_DEVICE_JWT_SECRET=replace-with-a-strong-secret
MOBILE_ONLINE_THRESHOLD_SECONDS=90
MOBILE_PAIR_QR_TTL_SECONDS=120
NEXT_PUBLIC_MOBILE_IOS_URL=
NEXT_PUBLIC_MOBILE_ANDROID_URL=
