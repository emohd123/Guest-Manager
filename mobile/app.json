{
  "expo": {
    "name": "Events Hub",
    "slug": "events-hub",
    "version": "0.1.0",
    "scheme": "eventshub",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eventshub.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.eventshub.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS"
      ]
    },
    "icon": "./assets/events-hub-icon.png",
    "splash": {
      "image": "./assets/events-hub-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1020"
    },
    "web": {},
    "extra": {
      "apiBaseUrl": "https://events-hub-vert.vercel.app",
      "appUrl": "https://events-hub-vert.vercel.app",
      "supportUrl": "https://events-hub-vert.vercel.app/contact",
      "privacyPolicyUrl": "https://events-hub-vert.vercel.app/privacy-policy",
      "termsOfServiceUrl": "https://events-hub-vert.vercel.app/terms-of-service",
      "appVersion": "0.1.0",
      "eas": {
        "projectId": "7c69d004-775a-4522-afb7-570888702e61"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Events Hub uses the camera to scan tickets and attendee QR codes during live event check-in."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "general"
        }
      ]
    ],
    "owner": "emohd123"
  }
}
